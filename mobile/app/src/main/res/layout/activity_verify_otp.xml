<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verify OTP"
            android:textColor="@color/brand_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/otp_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/brand_muted"
            android:text="Enter the 6-digit code sent to your email." />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/otp_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="OTP Code"
                android:inputType="number"
                android:maxLength="6"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/otp_verify_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Verify & Proceed"
            android:backgroundTint="@color/brand_pink"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/otp_resend_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Resend OTP"
            android:backgroundTint="@color/brand_surface"
            android:textColor="@color/brand_text" />

        <TextView
            android:id="@+id/otp_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#FF5A5A"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
