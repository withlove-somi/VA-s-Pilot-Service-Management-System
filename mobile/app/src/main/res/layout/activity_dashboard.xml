<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0518"
    android:padding="24dp">

    <TextView
        android:id="@+id/btn_open_drawer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="☰"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/avatar_placeholder"
        android:layout_width="36dp"
        android:layout_height="36dp"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="#20E000FF"
        app:strokeWidth="1dp"
        app:strokeColor="#E000FF"
        app:layout_constraintTop_toTopOf="@id/btn_open_drawer"
        app:layout_constraintBottom_toBottomOf="@id/btn_open_drawer"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="A"
            android:textColor="#E000FF"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/greeting_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btn_open_drawer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hi, "
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dashboard_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Test Admin"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#207A00FF"
            app:cardCornerRadius="6dp"
            app:strokeColor="#7A00FF"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/dashboard_verified"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="#D8B4FE"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="UNRANKED" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <TextView
        android:id="@+id/dashboard_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#9CA3AF"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/greeting_row"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="admin@test.com" />

    <TextView
        android:id="@+id/welcome_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Welcome back, Commander."
        android:textColor="#9CA3AF"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/dashboard_email"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_place_order_dummy"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:text="Place New Order"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#E000FF"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/welcome_sub" />

    <TextView
        android:id="@+id/orders_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Active Orders"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btn_place_order_dummy"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/dashboard_refresh"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Refresh"
        android:textColor="#3B82F6"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="@id/orders_title"
        app:layout_constraintTop_toTopOf="@id/orders_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dashboard_orders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@id/orders_title"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@android:layout/simple_list_item_2" />

</androidx.constraintlayout.widget.ConstraintLayout>