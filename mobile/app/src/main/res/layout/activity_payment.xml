<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/payment_refresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Orders"
            android:backgroundTint="@color/brand_surface"
            android:textColor="@color/brand_text" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/payment_orders"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/payment_order_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Order ID"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/payment_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Amount"
                android:inputType="numberDecimal"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/payment_reference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Payment reference"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/payment_pick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Choose Receipt Image"
            android:backgroundTint="@color/brand_surface"
            android:textColor="@color/brand_text" />

        <Button
            android:id="@+id/payment_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Submit Payment"
            android:backgroundTint="@color/brand_pink"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/payment_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#FF5A5A"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
