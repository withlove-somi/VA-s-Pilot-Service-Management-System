<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/profile_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textColor="@color/brand_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profile_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Email"
            android:textColor="@color/brand_muted" />

        <TextView
            android:id="@+id/profile_verified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Verified: No"
            android:textColor="@color/brand_muted" />

        <Button
            android:id="@+id/profile_pick_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Choose Profile Image"
            android:backgroundTint="@color/brand_surface"
            android:textColor="@color/brand_text" />

        <Button
            android:id="@+id/profile_update_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Update Profile Image"
            android:backgroundTint="@color/brand_pink"
            android:textColor="@android:color/white" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Verification Request"
            android:textColor="@color/brand_text"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/profile_verify_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Full name"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/profile_verify_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/profile_verify_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone number"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/profile_verify_id_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Government ID type"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/profile_verify_id_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Government ID number"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/profile_pick_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Choose ID Photo"
            android:backgroundTint="@color/brand_surface"
            android:textColor="@color/brand_text" />

        <Button
            android:id="@+id/profile_pick_selfie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Choose Selfie with ID"
            android:backgroundTint="@color/brand_surface"
            android:textColor="@color/brand_text" />

        <Button
            android:id="@+id/profile_submit_verification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Submit Verification"
            android:backgroundTint="@color/brand_pink"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/profile_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#FF5A5A"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
