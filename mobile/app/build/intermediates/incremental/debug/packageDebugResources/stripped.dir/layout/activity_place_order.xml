<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Place Order"
            android:textColor="@color/brand_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_fullname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Full name"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:enabled="false"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_ign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="IGN"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_account_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Account ID"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_server_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Server ID"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_pilot_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pilot login method"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_pilot_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pilot login email"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink"
            app:passwordToggleEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_pilot_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pilot login password"
                android:inputType="textPassword"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_pilot_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pilot login number"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_game"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Game"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_current_rank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Current rank"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_target_rank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Target rank"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_stars_needed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Stars needed"
                android:inputType="number"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Notes"
                android:minLines="2"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_payment_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Payment mode"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/brand_pink">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/order_total_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Total price"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/order_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Submit Order"
            android:backgroundTint="@color/brand_pink"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/order_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#FF5A5A"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
